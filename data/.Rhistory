"slovak|eslovaquia",
"slovenia|eslovenia",
"sweden|suecia",
"switzerland|suiza|schweiz|suisse",
"t.rkiye|turkey|turqu.a",
"united.?kingdom|u\\.?k\\b|great.?britain|england",
"united.?states|u\\.?s\\.?a|\\busa\\b|estados.?unidos"
)
pattern <- paste(ocde_patterns, collapse = "|")
# Patrón explícito de exclusión
exclude_pattern <- "north.?korea|corea.?del.?norte|dprk"
df$ocde <- as.integer(
grepl(pattern, df[[country_col]], ignore.case = TRUE, perl = TRUE) &
!grepl(exclude_pattern, df[[country_col]], ignore.case = TRUE)
)
return(df)
}
add_latam_flag <- function(df, country_col = "country") {
latam_patterns <- c(
# Centroamérica
"belize|belice",
"costa.?rica",
"el.?salvador",
"guatemal",
"hondur",
"m.xico|mexico",
"nicarag",
"panam.",                             # Panamá / Panama
# Sudamérica
"argentin",
"bolivi",
"brazil|brasil",
"chile",
"colombi",
"ecuador",
"french.?guiana|guyana.?franc|guayana.?franc",
"^guyana$|\\bguyana\\b(?!.*french|.*franc)",  # Guyana pero no French Guiana
"paragua",
"per.\\b|\\bper.\\b",                # Perú / Peru, word boundary para no atrapar "pered"
"surinam",
"urugua",
"venezuel",
# Caribe
"caribbean|caribe",
"cuba",
"dominican|rep.*dominicana|dominicana",
"ha.ti",                             # Haití / Haiti
"guadeloupe|guadalupe",
"martinique|martinica",
"puerto.?rico",
"saint.?barth|san.?barth|st.?barth",
"saint.?martin|san.?mart.n|st.?martin(?!.*sint)"  # excluye Sint Maarten (parte holandesa) si quieres
)
pattern <- paste(latam_patterns, collapse = "|")
df$latam <- as.integer(
grepl(pattern, df[[country_col]], ignore.case = TRUE, perl = TRUE)
)
return(df)
}
# Uso
df <- add_ocde_flag(df, country_col = "country")
df <- add_latam_flag(df, country_col = "country")
# revision
ocde = df |> distinct(country, ocde) |> filter(ocde == 1)
latam  = df |> distinct(country, latam) |> filter(latam == 1)
View(ocde)
rm(list = ls())
